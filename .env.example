# Quantum LMS Environment Variables
# Copy this file to .env and fill in your actual values

# Groq API Key (Required for AI Chatbot and Video Generation)
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Flask Secret Key (Used for session encryption)
# Generate a random string or use any secure value
SECRET_KEY=your-secret-key-here-change-this

# Email Configuration (Optional - for alert notifications)
# Gmail App Password: https://support.google.com/accounts/answer/185833
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password-here
